@startuml
skinparam stateFontSize 13

[*] --> Lead

Lead --> OportunidadCualificada : cualificar
Lead --> NoViable : descartar (no viable)

OportunidadCualificada --> PropuestaEnElaboracion : iniciar propuesta
OportunidadCualificada --> NoViable : descartar

PropuestaEnElaboracion --> PropuestaEnviada : enviar propuesta

PropuestaEnviada --> PropuestaEnElaboracion : solicitar cambios
PropuestaEnviada --> Ganada : aceptar
PropuestaEnviada --> Perdida : rechazar (sin negociación)

NoViable --> [*]
Ganada --> [*]
Perdida --> [*]

state "Lead" as Lead
state "Oportunidad Cualificada" as OportunidadCualificada
state "Propuesta en Elaboración" as PropuestaEnElaboracion
state "Propuesta Enviada / En Negociación" as PropuestaEnviada
state "No Viable" as NoViable
state "Ganada" as Ganada
state "Perdida" as Perdida
@enduml